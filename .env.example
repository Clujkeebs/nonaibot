# ── REQUIRED ────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── TRADING MODE ─────────────────────────────────────────────────────────────
# Set to false ONLY when you are ready for live money
ALPACA_PAPER=true

# ── RISK CONTROLS ────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.05
MAX_SECTOR_PCT=0.25
MAX_CRYPTO_PCT=0.15
RISK_PER_TRADE_PCT=0.01
ATR_STOP_MULT=2.0
DAILY_LOSS_LIMIT_PCT=0.03
WEEKLY_LOSS_LIMIT_PCT=0.07
MAX_OPEN_POSITIONS=25
PORTFOLIO_HEAT_MAX=0.80

# ── STRATEGY TOGGLES ─────────────────────────────────────────────────────────
ENABLE_TREND_FOLLOWING=true
ENABLE_MEAN_REVERSION=true
ENABLE_VOLATILITY_BREAKOUT=true
ENABLE_SECTOR_ROTATION=true
ENABLE_CRYPTO_MOMENTUM=true
ENABLE_AI_LAYER=true

# ── EXECUTION ────────────────────────────────────────────────────────────────
ORDER_RETRY_LIMIT=3
ORDER_FILL_TIMEOUT=60
SLIPPAGE_LIMIT_PCT=0.003
MIN_NOTIONAL=100

# ── ALERTS (optional) ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
ALERT_ON_TRADE=true
ALERT_ON_ERROR=true

# ── INFRASTRUCTURE ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=trading_bot.db
